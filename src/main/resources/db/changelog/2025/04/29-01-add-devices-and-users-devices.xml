<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.5.xsd">

    <changeSet id="29-01-create-devices-table" author="minhpt">
        <createTable tableName="devices">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_devices"/>
            </column>
            <column name="create_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="create_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_date" type="TIMESTAMP"/>
            <column name="last_modified_by" type="BIGINT"/>
            <column name="is_delete" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_date" type="TIMESTAMP"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="serial_number" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uc_devices_serial_number"/>
            </column>
            <column name="type" type="VARCHAR(50)"/>
            <column name="status" type="VARCHAR(50)"/>
        </createTable>
    </changeSet>

    <changeSet id="29-01-create-users-devices-table" author="minhpt">
        <createTable tableName="users_devices">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="device_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="users_devices" columnNames="user_id, device_id" constraintName="pk_users_devices"/>
        <addForeignKeyConstraint
                baseTableName="users_devices" baseColumnNames="user_id"
                constraintName="fk_users_devices_user"
                referencedTableName="users" referencedColumnNames="id"/>
        <addForeignKeyConstraint
                baseTableName="users_devices" baseColumnNames="device_id"
                constraintName="fk_users_devices_device"
                referencedTableName="devices" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
